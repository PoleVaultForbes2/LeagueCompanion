# Backend runtime configuration.
# Use the Supabase Postgres connection string from Project Settings > Database.
# URL-encode special characters in the database password.
DATABASE_URL=postgresql://postgres.<project-ref>:<url-encoded-password>@<pooler-host>:6543/postgres
RIOT_API_KEY=RGAPI-your-riot-api-key
RIOT_PLATFORM=na1
PORT=5000
